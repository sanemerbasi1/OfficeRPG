  triggerOnlyOnce: 1
  sequence:
  - type: 0
    textContent: Welcome new worker. Its nice to meet you!
    menuOrSceneName: 
  - type: 0
    textContent: Oh, I didn't ask for your name yet.
    menuOrSceneName: 
  - type: 1
    textContent: What is your name?
    menuOrSceneName: 
  - type: 0
    textContent: Oh so you are <b>{name}</b>. Its a good name!
    menuOrSceneName: 
  - type: 0
    textContent: Lets look at your stats now.
    menuOrSceneName: 
  - type: 3
    textContent: 
    menuOrSceneName: statcreationui
  - type: 0
    textContent: Now lets look at your traits.
    menuOrSceneName: 
  - type: 4
    textContent: 
    menuOrSceneName: traitui
  - type: 0
    textContent: Okay everything is set and ready!
    menuOrSceneName: 
