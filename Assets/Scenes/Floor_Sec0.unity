    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 0
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 0
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: fourthchoice
    jumpToAfterStep: 
