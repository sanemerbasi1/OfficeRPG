--- !u!114 &330238999
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 330238996}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7a48f13c3c74b4f7eb9ce291abdf24d0, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::WorldTrigger
  triggerName: EnemyTrigger1
  triggerOnlyOnce: 1
  fieldEnemyUnit: {fileID: 212823895}
  sequence:
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: RIVAL
    textContent: You are <b>{name}</b>, right?
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 1376746750}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: RIVAL
    textContent: The one they just hired.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 1376746750}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 9
    speakerName: Player Option
    textContent: 
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices:
    - choiceText: 1. Yes. Do we know each other?
      statReward: 0
      rewardAmount: 0
      targetStepID: 
    - choiceText: 2. I am trying to get to orientation.
      statReward: 0
      rewardAmount: 0
      targetStepID: 
    - choiceText: 3. That is what HR told me.
      statReward: 0
      rewardAmount: 0
      targetStepID: 
    - choiceText: 4. Is there a problem?
      statReward: 0
      rewardAmount: 0
      targetStepID: 
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: RIVAL
    textContent: I checked your Linked profile, you know.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 1376746750}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: RIVAL
    textContent: I am not impressed.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 1376746750}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: RIVAL
    textContent: I have experience in three of the departments they listed.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 1376746750}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: RIVAL
    textContent: I waited. I followed up. I adjusted my portfolio every time they
      changed the requirements.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 1376746750}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: RIVAL
    textContent: And then you showed up.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 1376746750}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 9
    speakerName: Player Options
    textContent: 
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices:
    - choiceText: 1. I am sorry, but this is not my decision.
      statReward: 0
      rewardAmount: 0
      targetStepID: 
    - choiceText: 2. I didn't do anything special.
      statReward: 0
      rewardAmount: 0
      targetStepID: 
    - choiceText: 3. There is nothing I can do.
      statReward: 0
      rewardAmount: 0
      targetStepID: 
    - choiceText: 4. Well, they choose me...
      statReward: 0
      rewardAmount: 0
      targetStepID: 
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: RIVAL
    textContent: People keep saying that.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 1376746750}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: RIVAL
    textContent: No one makes the decision. Everyone just happens to stand near it.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 1376746750}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: NARRATOR
    textContent: The stranger is not entirely wrong.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 1376746750}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: <color=#0953BA>NARRATOR
    textContent: <i>A fair system would have made the comparison clear. An honest
      system would have explained the decision.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: <color=#0953BA>NARRATOR
    textContent: <i>This one produced a winner and left the rest of the room to interpret
      the damage.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: RIVAL
    textContent: Do you know what they told me?
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 1376746750}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: RIVAL
    textContent: "\u201CUnfortunately we decided to move on with another candidate
      but your profile remains under consideration for future opportunities.\u201D"
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 1376746750}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: RIVAL
    textContent: At least seven different companies e-mailed that sentence to me.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 1376746750}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: RIVAL
    textContent: Now I get to meet this said candidate.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 1376746750}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: RIVAL
    textContent: A rare opportunity, really.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 1376746750}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
