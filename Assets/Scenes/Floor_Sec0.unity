    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 0
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 0
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: three
    jumpToAfterStep: 
    type: 0
    speakerName: CO-WORKER
    textContent: Maybe.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 0
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 0
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: CO-WORKER
    textContent: Hold on to that.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 0
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 0
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: mainstorythree
    type: 0
    speakerName: CO-WORKER
    textContent: This place has a way of making resistance feel immature.
