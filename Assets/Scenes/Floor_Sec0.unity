  triggerName: DialogueTrigger
  triggerOnlyOnce: 1
  fieldEnemyUnit: {fileID: 0}
  sequence:
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: <color=#0953BA>NARRATOR
    textContent: <i>The Receptionist looks up with the exact amount of warmth required
      for the role.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: <color=#0953BA>NARRATOR
    textContent: "<i>Not unkind or personal. Just\u2026efficient."
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: RECEPTIONIST
    textContent: Good morning. Welcome to DIYU Group.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: RECEPTIONIST
    textContent: Do you have an appointment?
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 9
    speakerName: Player Options
    textContent: 
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices:
    - choiceText: 1. Yes. I am here for the 9:00 AM interview.
      statReward: 0
      rewardAmount: 0
      targetStepID: 
    - choiceText: 2. Good morning. I believe HR is expecting me.
      statReward: 0
      rewardAmount: 0
      targetStepID: 
    - choiceText: 3. I am here for the interview. I arrived a little early.
      statReward: 0
      rewardAmount: 0
      targetStepID: 
    - choiceText: 4. I have an interview at 9:00. I would like to check in.
      statReward: 0
      rewardAmount: 0
      targetStepID: 
