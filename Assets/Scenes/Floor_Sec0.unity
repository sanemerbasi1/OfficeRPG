    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 0
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 0
    choices:
    - choiceText: 1. Thank you.
      statReward: 0
      rewardAmount: 0
      targetStepID: firstchoice
    - choiceText: 2. Will I see you again?
      statReward: 0
      rewardAmount: 0
      targetStepID: secondchoice
    - choiceText: 3. What happens when I go upstairs?
