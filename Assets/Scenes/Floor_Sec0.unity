    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: CO-WORKER
    textContent: Unofficially, you need supplies.
