    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 0
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 0
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: CO-WORKER
    textContent: 'Then a version of yourself that can handle it. '
