  m_Script: {fileID: 11500000, guid: 7a48f13c3c74b4f7eb9ce291abdf24d0, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::WorldTrigger
  triggerName: NarrativeTrigger
  triggerOnlyOnce: 1
  fieldEnemyUnit: {fileID: 0}
  sequence:
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: <color=#0953BA>NARRATOR
    textContent: <i>It is 8.45 AM.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: <color=#0953BA>NARRATOR
    textContent: <i>The interview starts in fifteen minutes.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: <color=#0953BA>NARRATOR
    textContent: "<i>The Applicant has done the reasonable things. Arrived early.
      Dressed carefully. Learned the company\u2019s language well enough to repeat
      it back with confidence.\n"
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: <color=#0953BA>NARRATOR
    textContent: <i>There is still time to breathe, but not enough time to become
      someone else.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: <color=#0953BA>NARRATOR
    textContent: <i>The lobby is quiet. The Reception desk waits at the center of
      it, clean and deliberate, as if every person who enters this building is expected
      to stand in exactly this place.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: <color=#0953BA>NARRATOR
    textContent: <i>Your first task is simple.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: <color=#0953BA>NARRATOR
    textContent: <i>Be seen. Be cleared. Be sent forward.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 8
    speakerName: 
    textContent: <b>OBJECTIVE UPDATED:</b> Check in at Reception.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 1
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 1
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  ui: {fileID: 1655853756}
  battleManager: {fileID: 1036568086}
