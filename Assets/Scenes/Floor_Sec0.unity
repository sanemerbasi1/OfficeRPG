    battleLoopMusic: {fileID: 0}
  - stepID: firstchoice
    jumpToAfterStep: 
    type: 0
    speakerName: CO-WORKER
    textContent: Do not thank me yet.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 0
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 0
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: mainstorysix
    type: 0
    speakerName: CO-WORKER
    textContent: Just keep moving.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 0
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 0
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: secondchoice
    jumpToAfterStep: 
    type: 0
    speakerName: CO-WORKER
    textContent: Maybe.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 0
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 0
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: mainstorysix
    type: 0
    speakerName: CO-WORKER
    textContent: If I am still assigned to this floor.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 0
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 0
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: thirdchoice
    jumpToAfterStep: 
    type: 0
    speakerName: CO-WORKER
    textContent: You will be tested by people who believe they are only doing their
      jobs.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 0
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 0
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: 
    type: 0
    speakerName: CO-WORKER
    textContent: That makes them harder to hate.
    menuName: 
    encounterData: {fileID: 0}
    npcAnimator: {fileID: 0}
    targetUIElements: []
    targetUIState: 0
    isTemporary: 0
    activeDuration: 0
    waitToFinish: 0
    choices: []
    battleStartSound: {fileID: 0}
    battleLoopMusic: {fileID: 0}
  - stepID: 
    jumpToAfterStep: mainstorysix
    type: 0
    speakerName: CO-WORKER
    textContent: And harder to defeat.
